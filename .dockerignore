# VCS
.git
.gitignore

# Local secrets and environment overrides (production VITE_* must come from build ARG/ENV only)
frontend/.env.local
frontend/.env.*.local
**/.env.local
**/.env.*.local
.env
**/.env

# Dependencies
**/node_modules
frontend/node_modules
backend/.venv
.venv
**/__pycache__
**/*.py[cod]
**/*.egg-info

# Test and coverage caches
**/.pytest_cache
**/.coverage
**/coverage
**/htmlcov
frontend/coverage
backend/.pytest_cache

# Local frontend build output (image rebuilds from source)
frontend/dist

# CDK generated artifacts
deployment/cdk/cdk.out
deployment/cdk/dist
deployment/cdk/node_modules

# IDE / editor
.idea
.vscode
.cursor
.kiro
*.swp
*.swo
*~

# Temporary files and logs
*.log
**/*.log
tmp
temp
*.tmp
.DS_Store
Thumbs.db

# Documentation and local-only artifacts not required by Dockerfile
documentation
PROJECT_STATUS.md
README.md
dev.cmd
test.cmd
test
changed-files.txt

# backend/data — exclude commercial/user/runtime by default; allow approved editorial release corpus only
backend/data/*
!backend/data/editorial/
backend/data/editorial/*
!backend/data/editorial/content-store.json
!backend/data/published/
backend/data/published/*
!backend/data/published/manual/
!backend/data/published/manual/**
!backend/data/published/glossary/
!backend/data/published/glossary/**
!backend/data/published/knowledge-base/
!backend/data/published/knowledge-base/**
!backend/data/published/website/
!backend/data/published/website/**
!backend/data/manual/
backend/data/manual/*
!backend/data/manual/images/
!backend/data/manual/images/**
!backend/data/glossary/
backend/data/glossary/*
!backend/data/glossary/images/
!backend/data/glossary/images/**
!backend/data/knowledge-base/
backend/data/knowledge-base/*
!backend/data/knowledge-base/images/
!backend/data/knowledge-base/images/**
!backend/data/website/
backend/data/website/*
!backend/data/website/images/
!backend/data/website/images/**
!backend/data/config/
backend/data/config/*
!backend/data/config/public-languages.json

# Keep commercial/user/runtime artifacts out of the image build context
backend/data/preferences/
backend/data/entitlements/
backend/data/legacy/
backend/data/.hfzwood-initialized.json
backend/data/**/*.tmp*
backend/data/**/.hfzwood-write-check-*
backend/data/**/.hfzwood-init-*
